{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-wp-runtime@1.1.0"
        }
    },
    "routes": [
        {
            "src": "/_next/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}